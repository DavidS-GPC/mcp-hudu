# Hudu base URL — your Hudu instance domain including /api/v1
# e.g. https://docs.yourcompany.com/api/v1
HUDU_BASE_URL=https://your-instance.example.com/api/v1

# Hudu API key — create at: Admin > API Keys > New API Key
HUDU_API_KEY=your_hudu_api_key_here

# Set to true to bypass SSL certificate errors (needed when behind a corporate SSL inspection proxy)
HUDU_IGNORE_TLS_ERRORS=true

# Cloudflare Access Service Token — required when Hudu is behind Cloudflare Zero Trust
# Create at: Zero Trust > Access > Service Auth > Service Tokens
CF_ACCESS_CLIENT_ID=your_client_id_here
CF_ACCESS_CLIENT_SECRET=your_client_secret_here

# Shared key that team members must provide to connect to this MCP server
# Generate a strong random string: openssl rand -hex 32
MCP_AUTH_KEY=change_me_to_a_strong_random_string

PORT=3002
NODE_ENV=production
